#include "ui/components/base.inc"

{
	menuDef
	{
		name			"sr_customize"
		rect			0 0 200 480 HORIZONTAL_ALIGN_LEFT VERTICAL_ALIGN_TOP
		focuscolor		COLOR_FOCUSED
		style			WINDOW_STYLE_FILLED
		backcolor		0 0 0 0.85
