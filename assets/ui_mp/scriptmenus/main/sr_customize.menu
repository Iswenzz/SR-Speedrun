		SR_BUTTON_LEFT(2, "^8Characters", scriptMenuResponse "character";, 1)
		SR_BUTTON_LEFT(3, "^8Sprays", scriptMenuResponse "spray";, 1)
		SR_BUTTON_LEFT(4, "^8Knifes", scriptMenuResponse "knife";, 1)
		SR_BUTTON_LEFT(5, "^8Knife Skins", scriptMenuResponse "knife_skin";, 1)
		SR_BUTTON_LEFT(6, "^8Gloves", scriptMenuResponse "glove";, 1)
		SR_BUTTON_LEFT(7, "^8Effects", scriptMenuResponse "fx";, 1)
	}
