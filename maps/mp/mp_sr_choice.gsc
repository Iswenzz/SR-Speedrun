SpawnCheck()
{
    level endon("game_ended");
    while (1) {
        level waittill("connected", player);
        player thread onPlayerSpawned();
    }
}

onPlayerSpawned() {
    self endon("disconnect");
    while (1) {
        self waittill("spawned_player");
        self thread text_spawn( "^1Welcome to ^2mp_sr_choice!", "^1Map created by - ^2Cam & Death!", "^1Huge thanks to My Boy\n^1-------^2Swaggy^1-------");
    }
}

text_spawn( cam1, cam2, cam3 )
{
    self endon( "intermission" );
    self endon( "disconnect" );
    self endon( "killthreads" );
    self endon( "game_ended" );

    if( isDefined( self.messageDone ) )
        return;

    self.messageDone = true;

    wait 5;

    notifyData = spawnStruct();
    notifyData.notifyText = cam1;
    notifyData.glowColor = (0, 0, 0);
    notifyData.duration = level.welcomeduration;

    notifyData.sort = 6;
    notifyData.hideWhenInMenu = true;
    self thread maps\mp\gametypes\_hud_message::notifyMessage( notifyData );

    wait 1;

    notifyData = spawnStruct();
    notifyData.notifyText = cam2;
    notifyData.glowColor = (0, 0, 0);
    notifyData.duration = level.welcomeduration;

    notifyData.sort = 6;
    notifyData.hideWhenInMenu = true;
    self thread maps\mp\gametypes\_hud_message::notifyMessage( notifyData );

    wait 1;

        notifyData = spawnStruct();
    notifyData.notifyText = cam3;
    notifyData.glowColor = (0, 0, 0);
    notifyData.duration = level.welcomeduration1;

    notifyData.sort = 8;
    notifyData.hideWhenInMenu = true;
    self thread maps\mp\gametypes\_hud_message::notifyMessage( notifyData );
}

secret_cp_system()
{
    trigger = getEntArray("secret_fail", "targetname");

    thread checkpoint1();
    thread checkpoint2();
    thread checkpoint3();
    thread checkpoint4();
    thread checkpoint5();


    for(i = 0; i < trigger.size; i++)
	{
	trigger[i] thread checkpoints_hard();
    }

}


checkpoints_hard()
{
    h_00 = getEnt("h_0", "targetname");
    h_01 = getEnt("h_1", "targetname");
    h_02 = getEnt("h_2", "targetname");
    h_03 = getEnt("h_3", "targetname");
    h_04 = getEnt("h_4", "targetname");
    h_05 = getEnt("h_5", "targetname");
    for(;;)
    {
        self waittill("trigger", player);

        if(player.secret == 0)
        {
			player setPlayerAngles( h_00.angles );
			player setOrigin( h_00.origin );
            player freezeControls( 1 );
            wait 0.1;
			player freezeControls( 0 );
        }
        else if(player.secret == 1)
        {
            player setPLayerAngles( h_01.angles );
            player setOrigin( h_01.origin );
            player freezeControls( 1 );
            wait 0.1;
            player freezeControls( 0 );
        }
        else if(player.secret == 2)
        {
            player setPlayerAngles( h_02.angles );
            player setOrigin( h_02.origin );
            player freezeControls( 1 );
            wait 0.1;
            player freezeControls( 0 );
        }
        else if(player.secret == 3)
        {
            player setPlayerAngles( h_03.angles );
            player setOrigin( h_03.origin );
            player freezeControls( 1 );
            wait 0.1;
            player freezeControls( 0 );
        }
        else if(player.secret == 4)
        {
            player setPlayerAngles( h_04.angles );
            player setOrigin( h_04.origin );
            player freezeControls( 1 );
            wait 0.1;
            player freezeControls( 0 );
        }
        else if(player.secret == 5)
        {
            player setPlayerAngleS( h_05.angles );
            player setOrigin( h_05.origin );
            player freezeControls( 1 );
            wait 0.1;
            player freezeControls( 0 );
        }
    }
}

