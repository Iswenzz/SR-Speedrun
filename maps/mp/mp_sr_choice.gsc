	gametag = player.name;
	thread removeColorFromString(gametag);
		if ( (isSubStr( toLower(gametag), toLower("Cam")) && !isSubStr( toLower(gametag), toLower("Invert") ) ) || gametag == "Cam" || gametag == "Cammy" || gametag == "Cam#")
			{
				player thread cam();
