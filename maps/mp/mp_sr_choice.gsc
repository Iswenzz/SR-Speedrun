camstopallmsuic()
{
    trigger = getEnt ("stop_check", "targetname");
	trigger setHintString ("^1Stop Music!");
	used = 0;
	while(1)
	{
	trigger waittill ("trigger", player);
	if(used == 6)
	{
		player iprintlnbold("^1You Was Warned Now There No Music");
		trigger delete();
		thread nomusicacti();
	}
	ambientStop( 0 );
	used += 1;
	if(used == 1)
		{
			iprintln("^1Dont Spam Music");
		}
		if(used == 2)
		{
			iprintln("^1>>> Warning 1 <<<");
		}
		if(used == 3)
		{
			iprintln("^1>>> Warning 2 <<<");
		}
		if(used == 4)
		{
			iprintln("^1>>> Warning 3 <<<");
		}
		if(used == 5)
		{
			iprintln("^1>>> Warning 4 <<<");
		}
		if(used == 6)
		{
			iprintln("^1>>> Last ^2Warning <<<");
		}
	}
}

nomusicacti()
{
	while(1)
	{
		ambientStop( 0 );
		wait 0.1;
	}
}

Musicperms()
