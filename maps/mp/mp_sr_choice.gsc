#include braxi\_common;
#include maps\mp\_utility;
#include maps\mp\gametypes\_hud_util;
#include common_scripts\utility;

main()
{
    maps\mp\_load::main();



    game["allies"] = "marines";
    game["axis"] = "opfor";
    game["attackers"] = "axis";
    game["defenders"] = "allies";
    game["allies_soldiertype"] = "desert";
    game["axis_soldiertype"] = "desert";

    setDvar("r_gamma","1");
    setDvar("r_specularcolorscale", "1");
    setDvar("r_glowbloomintensity0","1");
    setDvar("compassmaxrange","1800");
    setDvar("bg_fallDamageMaxHeight", "99999");
    setDvar("bg_fallDamageMinHeight", "99998");
	precacheItem("rpg_mp");
	precacheItem("tac_deagle_mp");

	precacheModel("playermodel_iron_spider");
	  precacheshader("mtl_iron_spider_body");
    precacheshader("mtl_chucky_eyes");


	//SR Code
		thread sr\api\_speedrun::createNormalWays("Easy;Medium;Hard;");

	//Credits n Text
	thread iPrint();

	//Velo M Test
	//thread onPlayerSpawn();

	//xM# Tag Check
	// thread epicxmnoncebullshit();

	//Player Notify Spawn Settings
	level.welcomeduration = 10;
	thread SpawnCheck();

	// Map Ways n Settings

	thread RPG_Hard();
	thread secret_cp_system();
	thread map_shoot();
	thread map_shoot1();
	thread hardroof();

	//Da Bois Stuff
	Swaggy_checker();
	cam_check();
	thread Musicperms();

	//Cam
	thread hard_end();
	thread inter_end();
	thread easy();
	thread hard();
	thread m();



}

 hard_end()
{
		trig = getEnt("hard_end", "targetname");
		for(;;)
		{
			trig waittill("trigger", player);
			player thread sr\api\_speedrun::finishWay("normal_2");

		}
}

 inter_end()
{
		trig = getEnt("inter_end", "targetname");
		for(;;)
		{
			trig waittill("trigger", player);
			player thread sr\api\_speedrun::finishWay("normal_1");
		}
}

//////////////////////////////////////////////////////////////////////////////////////////////////////// Map ways


easy()
{
	trig = getEnt("easy_enter", "targetname");
	o = getEnt("origin_easy", "targetname");
	for (;;)
	{
		trig waittill("trigger", player);
	   // player iPrintLn("^1Easy Way\n^4Checkpoints = 0");
		player freezeControls( 1 );
		player setOrigin(o.origin);
		player setPlayerAngles(o.angles);
		wait 0.1;
		player freezeControls( 0 );

	}
}



m()
{
	trig = getEnt("m_enter", "targetname");
	o = getEnt("o_m_enter", "targetname");
	for (;;)
	{
		trig waittill("trigger", player);
		player thread sr\api\_speedrun::changeWay("normal_1");
		//player iPrintLn("^1Medium Way\n^4Checkpoints = 1");
		player freezeControls( 1 );
		player setOrigin(o.origin);
		player setPlayerAngles(o.angles);
		wait 0.1;
		player freezeControls( 0 );

	}
}

hard()
{
	trig = getEnt("hard_enter", "targetname");
	o = getEnt("hard_spawn", "targetname");
	for (;;)
	{
		trig waittill("trigger", player);
		player thread sr\api\_speedrun::changeWay("normal_2");
		//player iPrintLn("^1Hard Way\n^4Checkpoints = 5");
		player freezeControls( 1 );
		player setOrigin(o.origin);
		player setPlayerAngles(o.angles);
		wait 0.1;
		player freezeControls( 0 );
		player.secret = 0;
	}
}
/////////////////////////////////////////////////////////////////////////////////////////////////////// Map Settings
map_shoot()
{
	trig = getEnt("map_sign", "targetname");
	while(1)
	{
		trig waittill("trigger", player);

		player iPrintLnBold("^1mp_sr_choice");
		wait 7;
		player iPrintLnBold("^1Map By ^4: ^2Cam & Death");
		wait 7;
		player iPrintLnBold("^1Map Scripted By ^4: ^2Cam");
		wait 500;
	}
}

map_shoot1()
{
	trig = getEnt("map_sign1", "targetname");
	while(1)
	{
		trig waittill("trigger", player);

		player iPrintLnBold("^1mp_sr_choice");
		wait 7;
		player iPrintLnBold("^1Map By ^4: ^2Cam & Death");
		wait 7;
		player iPrintLnBold("^1Map Scripted By ^4: ^2Cam");
		wait 500;
	}
}
RPG_Hard()
{
	thread rpg_hard1();
	thread rpg_hard2();
}

rpg_hard1()
{
	trig = getEnt("rpg_1_hard", "targetname");

	     while ( true )
		{
			trig waittill("trigger", player);
			player giveWeapon("rpg_mp");
            player giveMaxAmmo("rpg_mp");
            player switchToWeapon("rpg_mp");
		}

}
rpg_hard2()
{
	trig = getEnt("rpg_2_hard", "targetname");

	     while ( true )
		{
			trig waittill("trigger", player);
			player giveWeapon("rpg_mp");
            player giveMaxAmmo("rpg_mp");
            player switchToWeapon("rpg_mp");
		}
}

iPrint()
{
	level waittill("round_started");
	while(1)
	{
	iPrintLn("^3mp_sr_choice");
	wait 400;
	iPrintLn("^1Map By - Cam & Death");
	wait 400;
	iPrintLn("^6Huge Thanks To Swaggy For Helping Me Test Map");
	wait 400;
	}
}

Swaggy_checker()
{
    trig = getEnt("swag_here", "targetname");
    swaglong = "ff763ef30c40681936b7e8a403cea533";
    swagshort = "03cea533";
    trig waittill ("trigger", player);
	Guid = player getGUID();
    if((Guid == swagshort) || (Guid == swaglong))
    {
       iPrintLnBold("^1Swaggy ^7has just joined the server!");
	  //thread Musicperms();
    }
}

cam_check()
{
	trig = getEnt("cam_checker", "targetname");
	camlong = "d94ee7997034b22d12b0a0b4939de5c3";
	camshort = "939de5c3";
	trig waittill("trigger", player);
	cam = player getGUID();
	if((cam == camlong) || (cam == camshort))
	{
		iPrintLnBold("^1Cam ^7Has Just Joined The Server!");
		wait 2;
		AmbientStop();
		wait 0.1;
		AmbientPlay("cam");
	}

}



hardroof()
{
	trig = getEnt("hard_roof", "targetname");
	trig waittill("trigger", player);
	iPrintlnBold( player.name + " ^7Landed on ^1Hard Roof\n^4What a pro");
}

